[
  {
    "name": "E5T2: tapping Cancel on the booking confirmation shows a Yes/No confirmation",
    "steps": [
      { "send": { "text": "/book" }, "expect": [] },
      { "send": { "callback": "service:haircut" }, "expect": [] },
      { "send": { "callback": "barber:mustafa" }, "expect": [] },
      { "send": { "callback": "date:2026-06-19" }, "expect": [] },
      { "send": { "callback": "time:14:30" }, "expect": [] },
      { "send": { "text": "Jane Doe" }, "expect": [] },
      { "send": { "text": "555-123-4567" }, "expect": [] },
      {
        "send": { "callback": "confirm:cancel" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Cancel this booking?\n\nYour selections will be cleared and you'll be back at the main menu.",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "✅ Yes, cancel", "callback_data": "confirm:cancel:yes" },
                    { "text": "↩️ Keep booking", "callback_data": "confirm:cancel:no" }
                  ]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "E5T2: confirming Yes clears the booking",
    "steps": [
      { "send": { "text": "/book" }, "expect": [] },
      { "send": { "callback": "service:haircut" }, "expect": [] },
      { "send": { "callback": "barber:mustafa" }, "expect": [] },
      { "send": { "callback": "date:2026-06-19" }, "expect": [] },
      { "send": { "callback": "time:14:30" }, "expect": [] },
      { "send": { "text": "Jane Doe" }, "expect": [] },
      { "send": { "text": "555-123-4567" }, "expect": [] },
      { "send": { "callback": "confirm:cancel" }, "expect": [] },
      {
        "send": { "callback": "confirm:cancel:yes" },
        "expect": [
          { "method": "answerCallbackQuery", "payload": { "text": "Booking cancelled" } },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Booking cancelled. No problem — tap /start any time to book again."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "E5T2: confirming No restores the confirmation dialog",
    "steps": [
      { "send": { "text": "/book" }, "expect": [] },
      { "send": { "callback": "service:haircut" }, "expect": [] },
      { "send": { "callback": "barber:mustafa" }, "expect": [] },
      { "send": { "callback": "date:2026-06-19" }, "expect": [] },
      { "send": { "callback": "time:14:30" }, "expect": [] },
      { "send": { "text": "Jane Doe" }, "expect": [] },
      { "send": { "text": "555-123-4567" }, "expect": [] },
      { "send": { "callback": "confirm:cancel" }, "expect": [] },
      {
        "send": { "callback": "confirm:cancel:no" },
        "expect": [
          { "method": "answerCallbackQuery", "payload": { "text": "Kept your booking" } },
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ Confirm your booking\n\nService: Haircut (30 min)\nBarber: Mustafa\nDate: 2026-06-19\nTime: 14:30\nName: Jane Doe\nPhone: 555-123-4567\n\nTap confirm to lock it in, reschedule to pick a new time, or cancel."
            }
          }
        ]
      }
    ]
  }
]
